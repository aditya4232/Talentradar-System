# TalentRadar Environment Variables
# Copy this file to .env and add your API keys

# ═══════════════════════════════════════════════════════════
# GROQ API (Required for LLM parsing)
# ═══════════════════════════════════════════════════════════
GROQ_API_KEY=your_groq_api_key_here

# ═══════════════════════════════════════════════════════════
# OPTIONAL: Additional Job Board APIs (Get MORE India Jobs!)
# ═══════════════════════════════════════════════════════════

# Adzuna India API (FREE - https://developer.adzuna.com/)
# Provides jobs from Naukri, Monster, Indeed India, and more
# Get your free API credentials at: https://developer.adzuna.com/signup
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_API_KEY=your_adzuna_api_key

# RapidAPI JSearch (FREE tier - https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch)
# Aggregates Indeed, LinkedIn, Glassdoor, ZipRecruiter
# Get free API key at: https://rapidapi.com/hub
RAPIDAPI_KEY=your_rapidapi_key_here

# ═══════════════════════════════════════════════════════════
# OPTIONAL: Telegram Bot API (For scraping Telegram job channels)
# ═══════════════════════════════════════════════════════════
# Get bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# Telegram channel IDs to monitor (comma separated)
TELEGRAM_JOB_CHANNELS=@pythondevjobs,@reactjobs,@webdevjobs_india

# ═══════════════════════════════════════════════════════════
# HOW TO GET MORE INDIAN CANDIDATES:
# ═══════════════════════════════════════════════════════════
# 1. Get FREE Adzuna API (5 min signup):
#    - Visit https://developer.adzuna.com/signup
#    - Enter your details
#    - Copy APP_ID and API_KEY to .env
#    - Instantly get 100+ jobs from Naukri, Monster, Indeed India!
#
# 2. Get FREE RapidAPI JSearch key (2 min signup):
#    - Visit https://rapidapi.com/hub
#    - Sign up with Google/GitHub
#    - Subscribe to JSearch API (Free tier: 2500 requests/month)
#    - Copy X-RapidAPI-Key to .env
#    - Unlock Indeed, LinkedIn, Glassdoor India jobs!
#
# 3. Optional: Telegram bot for job channels
#    - Talk to @BotFather on Telegram
#    - Create new bot, get token
#    - Add token to .env
#    - Monitor Indian job channels in real-time!
