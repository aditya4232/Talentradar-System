# TalentRadar AI Platform - Environment Variables
# Copy this to .env and fill in your values

# === AI / LLM ===
# Get free at: https://console.groq.com (free 14,400 tokens/min)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-70b-versatile

# === GitHub API ===
# Get free at: https://github.com/settings/tokens (no scopes needed for public data)
GITHUB_TOKEN=your_github_token_here

# === Email (OPTIONAL - works without this, dry-run mode) ===
# Option 1: Resend (free 3000 emails/month) → https://resend.com
RESEND_API_KEY=

# Option 2: Gmail SMTP (free)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=your_app_password

FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=TalentRadar AI

# === App Settings ===
DEBUG=true
FRONTEND_URL=http://localhost:5173

# === Scraping Settings ===
SCRAPE_DELAY_MIN=3.0
SCRAPE_DELAY_MAX=8.0
MAX_CANDIDATES_PER_SCRAPE=50
